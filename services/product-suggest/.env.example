# Product Suggest Service Environment Variables

# Porta do serviço
PRODUCT_SUGGEST_PORT=3002

# Feature flag - habilita/desabilita sugestões online
ENABLE_ONLINE_PRODUCT_SUGGEST=true

# Ambiente (development, production)
NODE_ENV=development

# URL do feed oficial de providers (opcional)
# OFFICIAL_PROVIDER_FEED_URL=https://petmol.com.br/api/providers/feed.json

# Configurações de cache
# CACHE_TTL_SECONDS=604800  # 7 dias (default)
# CACHE_CHECK_PERIOD=86400  # Limpa cache expirado a cada 24h (default)

# Rate limiting
# RATE_LIMIT_MIN_TIME_MS=100  # 100ms entre requests = 10/seg (default)
# RATE_LIMIT_MAX_CONCURRENT=2  # Máximo 2 requests concorrentes (default)
