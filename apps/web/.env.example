# PETMOL Web — environment example for audit/review builds

# -----------------------------------------------------------------------------
# Base URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PHOTOS_BASE_URL=
BACKEND_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Integrations consumed by Next routes and browser flows
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_FUNCTIONS_URL=
FIREBASE_FUNCTIONS_URL=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
NEXT_PUBLIC_COSMOS_TOKEN=
COSMOS_TOKEN=
NEXT_PUBLIC_BARCODE_LOOKUP_API_KEY=

# GTIN RSC fica somente no backend. Nao colocar usuario/senha no frontend.

# -----------------------------------------------------------------------------
# Push / alert engine
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
FEATURE_REMINDERS_PUSH=false

# -----------------------------------------------------------------------------
# Places / location routing
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PLACES_ENABLED=false
PLACES_ENABLED=false
PLACES_AUTOCOMPLETE_ENABLED=false

# -----------------------------------------------------------------------------
# Sync / storage / auth dependencies
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Frontend feature flags
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_ENABLE_VIGIA=0
NEXT_PUBLIC_ENABLE_AUTO_DETECTOR=0
NEXT_PUBLIC_ENABLE_EVENT_NUDGE=0
NEXT_PUBLIC_THEME_PICKER_ENABLED=false

# -----------------------------------------------------------------------------
# Analytics / monitoring
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_HOTJAR_ID=
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Build workaround for monorepo lockfile issues
# -----------------------------------------------------------------------------
NEXT_IGNORE_INCORRECT_LOCKFILE=1
