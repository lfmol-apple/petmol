# ===================================
# PETMOL Web App - Environment Variables
# ===================================
# URL pública da aplicação (usada em QR codes de compartilhamento)
# Sem barra no final
NEXT_PUBLIC_SITE_URL=https://petshopbh.com


# ==============================================
# API Configuration
# ==============================================
# Development: http://localhost:8000
# Production with 1 domain: /api (API behind /api prefix via Nginx)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ==============================================
# Site URL (for Open Graph, canonical links, metadata)
# ==============================================
# Development: http://localhost:3000
# Production: https://yourdomain.com or http://YOUR_VPS_IP
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ==============================================
# Firebase Functions URL
# ==============================================
# Development (emulator): http://localhost:5001/YOUR_PROJECT_ID/us-central1
# Production: https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net
# IMPORTANTE: Não coloque chave do Google aqui! A chave fica no backend (Functions)
NEXT_PUBLIC_FIREBASE_FUNCTIONS_URL=http://localhost:5001/petmol-dev/us-central1

# ==============================================
# Google Maps API (apenas para visualização de mapas, NÃO para Places)
# ==============================================
# ATENÇÃO: Esta chave é APENAS para o mapa visual (quando necessário)
# Buscas de lugares são feitas via Firebase Functions (backend)
# Obtenha em: https://console.cloud.google.com/
# Habilite APENAS: Maps JavaScript API (NÃO Places API)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ==============================================
# Push Notifications (Web Push VAPID)
# ==============================================
# Gere com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ==============================================
# Feature Flags
# ==============================================
NEXT_PUBLIC_DEBUG=false

# ==============================================
# Analytics (Optional)
# ==============================================
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_HOTJAR_ID=

# ==============================================
# Sentry Error Tracking (Optional)
# ==============================================
NEXT_PUBLIC_SENTRY_DSN=

# ==============================================
# Build workaround for monorepo lockfile issues
# ==============================================
NEXT_IGNORE_INCORRECT_LOCKFILE=1

