# ===================================
# PETMOL - Environment Variables
# ===================================
# Copie este arquivo para .env.local e preencha com seus valores reais
# NUNCA commite arquivos .env com valores reais

# ===================================
# AMBIENTE GERAL
# ===================================
ENV=dev
DEBUG=true

# ===================================
# DATABASE
# ===================================
DATABASE_URL=sqlite:///./petmol.db

# ===================================
# JWT / AUTH
# ===================================
# Gere uma chave segura com: openssl rand -hex 32
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# SECRET_KEY (legacy - usado por petmol-api)
SECRET_KEY=your-secret-key-here-change-in-production

# ===================================
# ADMIN BOOTSTRAP
# ===================================
# (Opcional) Credenciais do primeiro admin (só usado se não houver admins)
ADMIN_MASTER_EMAIL=
ADMIN_MASTER_PASSWORD=
ADMIN_MASTER_ROLE=master
ADMIN_BOOTSTRAP_SECRET=

# ===================================
# CORS
# ===================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# ===================================
# API KEYS - MERCADO LIVRE
# ===================================
# Obtenha em: https://developers.mercadolivre.com.br/
MERCADOLIVRE_CLIENT_ID=your_client_id_here
MERCADOLIVRE_CLIENT_SECRET=your_client_secret_here
MERCADOLIVRE_ACCESS_TOKEN=

# ===================================
# API KEYS - GOOGLE MAPS/PLACES
# ===================================
# Obtenha em: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_PLACES_KEY=

# ===================================
# API KEYS - GEMINI (Para AI/Vision)
# ===================================
# API KEYS - GEMINI/GOOGLE AI (Para Vision AI)
# ===================================
# Obtenha em: https://makersuite.google.com/app/apikey
# Usado para OCR de carteirinhas de vacina
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ===================================
# API KEYS - OPENAI (Alternativa para AI)
# ===================================
OPENAI_API_KEY=

# ===================================
# FEATURE FLAGS
# ===================================
# Países com comparação de preços habilitada
PRICES_ENABLED_COUNTRIES=BR,AR,MX,CO,CL

# Habilita OCR de carteirinha de vacina com IA
# Requer GOOGLE_API_KEY configurada
FEATURE_AI_VACCINE_SCAN=false

# Habilita integração Google Maps
FEATURE_GOOGLE_MAPS_INTEGRATION=false

# Habilita sync multi-device (futuro)
FEATURE_FAMILY_SYNC=false

# Habilita push notifications
FEATURE_REMINDERS_PUSH=false

# ===================================
# RATE LIMITING
# ===================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ===================================
# CACHE
# ===================================
CACHE_TTL=300
SUGGEST_CACHE_TTL=180

# ===================================
# PUSH NOTIFICATIONS (Web Push)
# ===================================
# Gere keys com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com

# ===================================
# DEVELOPMENT FLAGS
# ===================================
# Permite criar tabelas automaticamente (apenas em dev)
ALLOW_CREATE_ALL=true
