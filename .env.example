# PETMOL — example environment for full audit package
# Copy the relevant sections to the actual runtime files (.env, .env.local, VPS secrets).

# -----------------------------------------------------------------------------
# Core app / backend
# -----------------------------------------------------------------------------
ENV=dev
DEBUG=true
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite:///./petmol.db
JWT_SECRET=change-me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
SECRET_KEY=change-me
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Admin bootstrap
# -----------------------------------------------------------------------------
ADMIN_MASTER_EMAIL=
ADMIN_MASTER_PASSWORD=
ADMIN_MASTER_NAME=
ADMIN_MASTER_ROLE=master
ADMIN_BOOTSTRAP_SECRET=

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# -----------------------------------------------------------------------------
# Cache / rate limit
# -----------------------------------------------------------------------------
CACHE_TTL=300
SUGGEST_CACHE_TTL=180
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
STORAGE_BACKEND=local
UPLOADS_DIR=uploads
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=petmol-uploads

# -----------------------------------------------------------------------------
# Push notifications / alerts
# -----------------------------------------------------------------------------
FEATURE_REMINDERS_PUSH=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:contato@example.com

# -----------------------------------------------------------------------------
# External APIs / integrations
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
MERCADOLIVRE_CLIENT_ID=
MERCADOLIVRE_CLIENT_SECRET=
MERCADOLIVRE_ACCESS_TOKEN=
PETZ_AFFILIATE_URL=
COBASI_AFFILIATE_URL=
PETLOVE_DOG_LIFE_URL=

# Cosmos Bluesoft API (backend only)
COSMOS_API_BASE_URL=https://api.cosmos.bluesoft.com.br
COSMOS_API_TOKEN=

# RSC GTIN API (backend only). Preencha usuario/senha reais no .env do backend/VPS, nunca no frontend.
GTIN_API_BASE_URL=https://gtin.rscsistemas.com.br
GTIN_API_USERNAME=
GTIN_API_PASSWORD=

# Open Food Facts (backend only, read-only GET with custom User-Agent)
OFF_API_BASE_URL=https://world.openfoodfacts.org
OFF_USER_AGENT=PETMOL/1.0 (contato@petmol.app)
OPF_API_BASE_URL=https://world.openproductsfacts.org

# -----------------------------------------------------------------------------
# Frontend / Next.js runtime
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PHOTOS_BASE_URL=
NEXT_PUBLIC_FIREBASE_FUNCTIONS_URL=
FIREBASE_FUNCTIONS_URL=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
NEXT_PUBLIC_COSMOS_TOKEN=
COSMOS_TOKEN=
NEXT_PUBLIC_BARCODE_LOOKUP_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_HOTJAR_ID=
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Frontend feature flags
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_ENABLE_VIGIA=0
NEXT_PUBLIC_ENABLE_AUTO_DETECTOR=0
NEXT_PUBLIC_ENABLE_EVENT_NUDGE=0
NEXT_PUBLIC_THEME_PICKER_ENABLED=false
NEXT_PUBLIC_PLACES_ENABLED=false
PLACES_ENABLED=false
PLACES_AUTOCOMPLETE_ENABLED=false
FEATURE_AI_VACCINE_SCAN=false
FEATURE_GOOGLE_MAPS_INTEGRATION=false
FEATURE_FAMILY_SYNC=false
PRICES_ENABLED_COUNTRIES=BR,AR,MX,CO,CL
NEXT_IGNORE_INCORRECT_LOCKFILE=1
ALLOW_CREATE_ALL=true
