{
  "name": "petmol-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "mobile": "cd apps/mobile && npm start",
    "mobile:ios": "cd apps/mobile && npm run ios",
    "mobile:android": "cd apps/mobile && npm run android",
    "web": "cd apps/web && npm run dev",
    "web:build": "cd apps/web && npm run build",
    "web:start": "cd apps/web && npm run start",
    "api": "cd services/price-service && PYTHONPATH=. .venv/bin/uvicorn src.main:app --reload --host 0.0.0.0 --port 8000",
    "api:dev": "cd services/price-service && PYTHONPATH=. .venv/bin/uvicorn src.main:app --reload --host 0.0.0.0 --port 8000"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "babel-preset-expo": "^54.0.9",
    "typescript": "~5.9.2"
  }
}
